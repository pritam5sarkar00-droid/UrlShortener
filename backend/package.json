{
  "name": "url-shortener-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "dev:all": "concurrently -n API,WORKER -c blue,magenta \"nodemon src/server.js\" \"nodemon src/worker.js\"",
    "start": "node src/server.js",
    "worker:dev": "nodemon src/worker.js",
    "worker": "node src/worker.js",
    "test": "node --experimental-test-module-mocks --test \"tests/unit/**/*.test.js\"",
    "test:integration": "node --experimental-test-module-mocks --test \"tests/integration/**/*.test.js\"",
    "test:all": "node --experimental-test-module-mocks --test \"tests/unit/**/*.test.js\" \"tests/integration/**/*.test.js\"",
    "loadtest:seed": "node scripts/loadtest/seed.mjs",
    "loadtest:redirect": "node scripts/loadtest/redirect.mjs",
    "loadtest:create": "node scripts/loadtest/create.mjs",
    "loadtest:ratelimit": "node scripts/loadtest/rate-limit-holds.mjs"
  },
  "dependencies": {
    "amqp-connection-manager": "^4.1.14",
    "amqplib": "^0.10.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "google-auth-library": "^9.15.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.5",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.6.13",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "autocannon": "^8.0.0",
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.0",
    "socket.io-client": "^4.8.1",
    "supertest": "^7.0.0"
  }
}
