# Use this file when running the backend directly (node src/server.js / npm run dev),
# NOT through docker-compose. Docker Compose uses the root-level .env.example instead.
#
# Setup: copy this file to backend/.env, then fill in real values.
#   cd backend
#   cp .env.example .env

# --- Postgres ---
# If you're running Postgres via docker-compose but the backend directly on
# your host, use localhost instead of the "postgres" service name below.
DATABASE_URL=postgresql://shortener:shortener_pass@localhost:5432/url_shortener
# DATABASE_SSL=true   # uncomment if using a managed provider like Neon (requires TLS)

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- RabbitMQ ---
RABBITMQ_URL=amqp://shortener:shortener_pass@localhost:5672

# --- App ---
# IMPORTANT: click counts require a worker to actually process them. Running
# `node src/server.js` alone is NOT enough - clicks get published to
# RabbitMQ but nothing consumes them, so click_count stays stuck at 0.
# Either run `node src/worker.js` in a second terminal, or set
# RUN_WORKER_INLINE=true below to run it inside this same process.
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# --- Auth ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# --- ID generation ---
SNOWFLAKE_WORKER_ID=1

# --- Rate limiting (per IP unless noted) ---
SHORTEN_RATE_LIMIT_ANON=5
SHORTEN_RATE_LIMIT_AUTH=30
REDIRECT_RATE_LIMIT=100
AUTH_RATE_LIMIT=10

# --- Cloud deployment only (e.g. Render + Neon/Upstash/CloudAMQP) ---
# Replace DATABASE_URL / REDIS_URL / RABBITMQ_URL above with the real
# connection strings from those dashboards, then also uncomment:
# DATABASE_SSL=true
# RUN_WORKER_INLINE=true

# --- Google OAuth login (optional - leave unset to disable) ---
GOOGLE_CLIENT_ID=

# --- Google Safe Browsing (optional - leave unset to skip the check) ---
GOOGLE_SAFE_BROWSING_API_KEY=

# --- Gemini page summarization (optional - free tier, leave unset to skip) ---
GEMINI_API_KEY=
