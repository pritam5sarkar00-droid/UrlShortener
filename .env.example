# --- Postgres ---
POSTGRES_USER=shortener
POSTGRES_PASSWORD=shortener_pass
POSTGRES_DB=url_shortener
DATABASE_URL=postgresql://shortener:shortener_pass@postgres:5432/url_shortener

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- RabbitMQ ---
RABBITMQ_USER=shortener
RABBITMQ_PASS=shortener_pass
RABBITMQ_URL=amqp://shortener:shortener_pass@rabbitmq:5672

# --- App ---
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# --- Auth ---
# No refresh-token flow in this design (single token, simpler for a student
# project) - so the expiry is set generously rather than the typical 15m.
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# --- ID generation (phase 2) ---
# Must be unique per running api instance once you scale to multiple replicas.
SNOWFLAKE_WORKER_ID=1

# --- Rate limiting (per IP unless noted) ---
SHORTEN_RATE_LIMIT_ANON=5
SHORTEN_RATE_LIMIT_AUTH=30
REDIRECT_RATE_LIMIT=100
AUTH_RATE_LIMIT=10

# --- Free-tier cloud deployment only (leave unset for local docker-compose) ---
# DATABASE_SSL=true        # required for managed Postgres providers like Neon
# RUN_WORKER_INLINE=true   # runs the worker's tasks inside this same process,
                            # for platforms with only one free always-on slot

# --- Google OAuth login (optional - leave unset to disable) ---
GOOGLE_CLIENT_ID=

# --- Google Safe Browsing (optional - leave unset to skip the check) ---
GOOGLE_SAFE_BROWSING_API_KEY=

# --- Gemini page summarization (optional - free tier, leave unset to skip) ---
GEMINI_API_KEY=
