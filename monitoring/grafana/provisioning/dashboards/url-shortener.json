{
  "title": "URL Shortener",
  "uid": "url-shortener-overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by route",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_request_duration_seconds_count[1m])) by (route, status_code)",
          "legendFormat": "{{route}} ({{status_code}})"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 latency by route",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cache hit ratio",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(cache_hits_total[5m])) / clamp_min(sum(rate(cache_hits_total[5m])) + sum(rate(cache_misses_total[5m])), 1e-9)"
        }
      ]
    },
    {
      "id": 4,
      "title": "Postgres lookups shielded by shortcode shield / sec",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(shortcode_shield_hits_total[5m]))"
        }
      ]
    },
    {
      "id": 5,
      "title": "Snowflake IDs generated / sec",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(snowflake_ids_generated_total[1m]))"
        }
      ]
    },
    {
      "id": 6,
      "title": "Click events: processed vs failed (worker)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(click_events_processed_total[5m]))",
          "legendFormat": "processed"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(click_events_failed_total[5m]))",
          "legendFormat": "failed -> DLQ"
        }
      ]
    }
  ]
}
